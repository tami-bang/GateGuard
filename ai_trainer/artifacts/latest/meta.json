{
  "model_version": "url-threat-v1",
  "task": "url_classification",
  "algorithm": "logistic_regression",
  "feature_mode": "tfidf_plus_numeric",
  "text_feature_source": "url",
  "feature_columns": [
    "url",
    "url_length",
    "host_length",
    "path_length",
    "query_length",
    "slash_count",
    "dot_count",
    "hyphen_count",
    "underscore_count",
    "question_mark_count",
    "ampersand_count",
    "equal_count",
    "digit_count",
    "special_char_count",
    "suspicious_keyword_hits",
    "has_suspicious_extension",
    "has_query",
    "is_ipv4_host",
    "subdomain_count"
  ],
  "numeric_feature_columns": [
    "url_length",
    "host_length",
    "path_length",
    "query_length",
    "slash_count",
    "dot_count",
    "hyphen_count",
    "underscore_count",
    "question_mark_count",
    "ampersand_count",
    "equal_count",
    "digit_count",
    "special_char_count",
    "suspicious_keyword_hits",
    "has_suspicious_extension",
    "has_query",
    "is_ipv4_host",
    "subdomain_count"
  ],
  "labels": ["benign", "malware", "phishing"],
  "combination_method": "scipy_hstack_sparse",
  "tfidf": {
    "analyzer": "char",
    "ngram_range": [3, 5],
    "min_df": 1,
    "max_features": 5000
